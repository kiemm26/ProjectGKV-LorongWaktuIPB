--- !u!114 &902081256
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 902081255}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ae174d1df6b2c4ac8a7d17e489db6be8, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  infoPanel: {fileID: 1427509526}
  contentSimple: {fileID: 1052996791}
  contentList: {fileID: 1864483271}
  contentText: {fileID: 1835883755}
  contentImages:
  - {fileID: 1267070813}
  infoText: 'Panel kolase ini memamerkan berbagai sumbangsih nyata IPB dalam memajukan
    pertanian, peternakan, kesehatan, serta kebijakan publik di Indonesia:


    -
    <b>Inovasi Varietas Unggul:</b> IPB sukses merakit dan melepas varietas tanaman
    produktif tinggi seperti Varietas Padi Unggul, Pepaya Calina (pepaya california
    lokal yang sangat populer di pasar), serta Varietas Cabai unggulan IPB yang tahan
    hama.


    - <b>Pendidikan & Pengabdian Masyarakat:</b> Pembentukan sistem pengabdian
    mahasiswa di desa melalui program BIMAS SSBM dan bimbingan lapangan langsung
    kepada petani setempat.


    - <b>Kesehatan Hewan:</b> Pendirian Rumah Sakit
    Hewan Pendidikan (RSHP) FKH IPB, yang menjadi salah satu pusat rujukan medis
    dan riset veteriner terbesar di Indonesia.


    - <b>Sistem Penerimaan Modern:</b>
    Adaptasi inovasi digital dalam sistem seleksi masuk perguruan tinggi yang memberikan
    akses luas dan transparan bagi pemuda-pemudi terbaik bangsa (Sutradara Penerimaan
    SNMPTN/UTBK).'
  infoImages:
  - {fileID: 21300000, guid: ac54a2a011d4a4ccc9f531b7a41ae597, type: 3}
  scrollRect: {fileID: 1377539498}
